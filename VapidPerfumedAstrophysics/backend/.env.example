# Copy to .env and fill in real values
DATABASE_URL=postgresql://user:password@host:5432/ria_db
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
FRONTEND_URL=https://your-frontend.vercel.app
PORT=3001
NODE_ENV=development

# Bootstrap admin seed (used by scripts/seed-admin.js only — never commit a real password)
BOOTSTRAP_ADMIN_PASSWORD=set-a-strong-password-here

# Supabase Storage (for profile pictures & broadcast images)
# Create a public bucket named "ria-media" in your Supabase project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
